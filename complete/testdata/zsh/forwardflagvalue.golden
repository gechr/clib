#compdef myapp

autoload -U is-at-least

_myapp() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    local -a __fwd=()
    _myapp_forwarded_flags
    _arguments "${_arguments_options[@]}" : \
        '(-p --profile)-p+[Active profile]: :_default' \
        '(-p --profile)--profile=[Active profile]: :_default' \
        '(-v --verbose)-v[Verbose output]' \
        '(-v --verbose)--verbose[Verbose output]' \
        ':: :_myapp_commands' \
        '*::: :->myapp' \
    && ret=0

    case $state in
    (myapp)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%%:*:*}:myapp-command-$line[1]:"
        case $line[1] in
            (deploy)
                _arguments "${_arguments_options[@]}" : \
                    '(-p --profile)-p+[Active profile]: :_default' \
                    '(-p --profile)--profile=[Active profile]: :_default' \
                    '--tags=[Tags to apply]:tags:{ local -a items; items=(${(f)"$(myapp --@complete=tag -- "${__fwd[@]}" 2>/dev/null)"}); _sequence compadd - "${(@)items}" }' \
                    '--target=[Target name]:target:{ local -a items; items=(${(f)"$(myapp --@complete=target -- "${__fwd[@]}" 2>/dev/null)"}); compadd -a items }' \
                && ret=0
            ;;
        esac
    ;;
    esac
}

_myapp_forwarded_flags() {
    local __skip_next=0 __fwd_name="" token i
    __fwd=()
    for ((i=2; i<CURRENT; i++)); do
        token=${words[i]}
        if (( __skip_next )); then
            if [[ -n "${__fwd_name}" ]]; then
                __fwd+=("--${__fwd_name}=${token}")
                __fwd_name=""
            fi
            __skip_next=0
            continue
        fi
        if [[ $token == -- ]]; then
            break
        fi
        case $token in
            (--profile|-p)
                __skip_next=1
                __fwd_name="profile"
                ;;
            (--profile=*)
                __fwd+=("$token")
                ;;
            (-p=*)
                __fwd+=("--profile=${token#-p=}")
                ;;
            (*)
                ;;
        esac
    done
}

(( $+functions[_myapp_commands] )) ||
_myapp_commands() {
    local commands; commands=(
        'deploy:Deploy a target' \
    )
    _describe -t commands 'myapp commands' commands "$@"
}

if [ "$funcstack[1]" = "_myapp" ]; then
    _myapp "$@"
else
    compdef _myapp myapp
fi
