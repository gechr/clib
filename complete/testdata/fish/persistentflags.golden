complete -c myapp -f

function __myapp_global_optspecs
    string join \n -- 'root-local' 'root-persistent'
end

function __myapp_needs_command
    set -l cmd (commandline -xpc)
    set -e cmd[1]
    argparse -s (__myapp_global_optspecs) -- $cmd 2>/dev/null
    or return
    if set -q argv[1]
        printf '%s\n' $argv
        return 1
    end
    return 0
end

function __myapp_using_subcommand
    set -l cmd (__myapp_needs_command)
    test -z "$cmd"
    and return 1
    for arg in $argv
        if contains -- $arg $cmd
            return 0
        end
    end
    return 1
end

function __myapp_using_primary_subcommand
    set -l cmd (__myapp_needs_command)
    test -z "$cmd"
    and return 1
    contains -- $cmd[1] $argv
end

complete -c myapp -n '__myapp_needs_command' -a parent -d "Parent command"

complete -c myapp -l root-persistent -d "Root persistent"
complete -c myapp -n '__myapp_needs_command' -l root-local -d "Root local"

complete -c myapp -n '__myapp_using_primary_subcommand parent; and not __myapp_using_subcommand child' -a child -d "Child command"
complete -c myapp -n '__myapp_using_primary_subcommand parent' -l parent-persistent -d "Parent persistent"
complete -c myapp -n '__myapp_using_primary_subcommand parent; and not __myapp_using_subcommand child' -l parent-local -d "Parent local"

complete -c myapp -n '__myapp_using_primary_subcommand parent; and __myapp_using_subcommand child' -l child-local -d "Child local"
