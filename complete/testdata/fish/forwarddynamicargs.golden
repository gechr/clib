complete -c myapp -f

function __myapp_tokens
    set -l major (string split . -- $version)[1]
    set -l tokens
    if test $major -ge 4
        set tokens (commandline -xpc)
    else
        set tokens (commandline -opc)
    end
    if set -q tokens[1]
        printf '%s\n' $tokens
    end
end

function __myapp_forwarded_flags
    set -l tokens (__myapp_tokens)
    set -e tokens[1]
    set -l forwarded
    set -l skip_next 0
    set -l fwd_name
    for t in $tokens
        if test $skip_next -eq 1
            if set -q fwd_name[1]
                set -a forwarded "--$fwd_name=$t"
                set -e fwd_name
            end
            set skip_next 0
        else if test "$t" = --
            break
        else
            switch $t
            case --category -c
                set skip_next 1
                set fwd_name category
            case '--category=*' '-c=*'
                set -a forwarded (string replace -r -- '^-c=' '--category=' $t)
            case --filter
                set skip_next 1
                set fwd_name filter
            case '--filter=*'
                set -a forwarded $t
            end
        end
    end
    if set -q forwarded[1]
        printf '%s\n' $forwarded
    end
end

complete -c myapp -s c -l category -x -a "alpha beta gamma" -d "Target category"
complete -c myapp -l filter -r -d "Result filter"
complete -c myapp -s v -l verbose -d "Verbose output"

function __myapp_dynamic_args
    set -l tokens (__myapp_tokens)
    set -e tokens[1]
    set -l positional
    set -l skip_next 0
    set -l dashdash 0
    for t in $tokens
        if test $dashdash -eq 1
            set -a positional $t
        else if test $skip_next -eq 1
            set skip_next 0
        else if test "$t" = --
            set dashdash 1
        else
            switch $t
            case --category -c --filter
                set skip_next 1
            case '--category=*' '-c=*' '--filter=*'
                true
            case '-*'
                true
            case '*'
                set -a positional $t
            end
        end
    end
    set -l nargs (count $positional)
    set -l forwarded (__myapp_forwarded_flags)
    switch $nargs
        case 0
            myapp --@complete=items -- $forwarded
        case 1
            myapp --@complete=values -- $forwarded $positional
        case '*'
            myapp --@complete=values -- $forwarded $positional
    end
end

complete -c myapp -a "(__myapp_dynamic_args)" -f
