complete -c myapp -f

# Comma-separated tags completion
function __myapp_complete_tags
    set -l value (string replace -r '^--tags=' '' -- (commandline -ct))
    set -l _flag_tags (myapp --@complete=tag -- (__myapp_forwarded_flags))
    if string match -qr '^(?<prefix>.*,)' -- $value
        set -l selected (string split ',' -- $prefix)
        for col in $_flag_tags
            if not contains -- $col $selected
                printf '%s\n' "$prefix$col"
            end
        end
    else
        printf '%s\n' $_flag_tags
    end
end

function __myapp_tokens
    set -l major (string split . -- $version)[1]
    set -l tokens
    if test $major -ge 4
        set tokens (commandline -xpc)
    else
        set tokens (commandline -opc)
    end
    if set -q tokens[1]
        printf '%s\n' $tokens
    end
end

function __myapp_forwarded_flags
    set -l tokens (__myapp_tokens)
    set -e tokens[1]
    set -l forwarded
    set -l skip_next 0
    set -l fwd_name
    for t in $tokens
        if test $skip_next -eq 1
            if set -q fwd_name[1]
                set -a forwarded "--$fwd_name=$t"
                set -e fwd_name
            end
            set skip_next 0
        else if test "$t" = --
            break
        else
            switch $t
            case --profile -p
                set skip_next 1
                set fwd_name profile
            case '--profile=*' '-p=*'
                set -a forwarded (string replace -r -- '^-p=' '--profile=' $t)
            end
        end
    end
    if set -q forwarded[1]
        printf '%s\n' $forwarded
    end
end

function __myapp_global_optspecs
    string join \n -- 'p/profile=' 'v/verbose'
end

function __myapp_needs_command
    set -l cmd (__myapp_tokens)
    set -e cmd[1]
    argparse -s (__myapp_global_optspecs) -- $cmd 2>/dev/null
    or return
    if set -q argv[1]
        printf '%s\n' $argv
        return 1
    end
    return 0
end

function __myapp_using_subcommand
    set -l cmd (__myapp_needs_command)
    test -z "$cmd"
    and return 1
    for arg in $argv
        if contains -- $arg $cmd
            return 0
        end
    end
    return 1
end

function __myapp_using_primary_subcommand
    set -l cmd (__myapp_needs_command)
    test -z "$cmd"
    and return 1
    contains -- $cmd[1] $argv
end

complete -c myapp -n '__myapp_needs_command' -a deploy -d "Deploy a target"

complete -c myapp -s p -l profile -r -d "Active profile"
complete -c myapp -n '__myapp_needs_command' -s v -l verbose -d "Verbose output"

complete -c myapp -n '__myapp_using_primary_subcommand deploy' -l tags -x -kra "(__myapp_complete_tags)" -d "Tags to apply"
complete -c myapp -n '__myapp_using_primary_subcommand deploy' -l target -x -a "(myapp --@complete=target -- (__myapp_forwarded_flags))" -d "Target name"
