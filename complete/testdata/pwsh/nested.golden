# myapp PowerShell completion

using namespace System.Management.Automation
using namespace System.Management.Automation.Language

Register-ArgumentCompleter -Native -CommandName 'myapp' -ScriptBlock {
    param($wordToComplete, $commandAst, $cursorPosition)

    $commandElements = $commandAst.CommandElements
    $command = 'myapp'
    for ($i = 1; $i -lt $commandElements.Count; $i++) {
        $element = $commandElements[$i]
        if ($element -isnot [StringConstantExpressionAst] -or
            $element.StringConstantType -ne [StringConstantType]::BareWord) {
            break
        }
        $value = $element.Value
        if ($value -eq $wordToComplete) { break }
        if ($value.StartsWith('-')) { continue }
        $next = switch ("$command;$value") {
            'myapp;auth' { 'myapp;auth'; break }
            'myapp;auth;login' { 'myapp;auth;login'; break }
            'myapp;auth;logout' { 'myapp;auth;logout'; break }
            'myapp;run' { 'myapp;run'; break }
            default { '' }
        }
        if ($next -eq '') { break }
        $command = $next
    }
    $prev = ''
    if ($commandElements.Count -ge 1) {
        $lastText = $commandElements[-1].Extent.Text
        if ($wordToComplete -ne '' -and $lastText -eq $wordToComplete) {
            if ($commandElements.Count -ge 2) {
                $prev = $commandElements[-2].Extent.Text
            }
        } else {
            $prev = $lastText
        }
    }

    $completions = @(switch ($command) {
        'myapp' {
            [CompletionResult]::new('--verbose', '--verbose', [CompletionResultType]::ParameterName, 'Verbose')
            [CompletionResult]::new('auth', 'auth', [CompletionResultType]::ParameterValue, 'Manage authentication')
            [CompletionResult]::new('run', 'run', [CompletionResultType]::ParameterValue, 'Run command')
            break
        }
        'myapp;auth' {
            switch ($prev) {
                { $_ -in '--token' } {
                    break
                }
                default {
                    [CompletionResult]::new('--token', '--token', [CompletionResultType]::ParameterName, 'Auth token')
                    [CompletionResult]::new('login', 'login', [CompletionResultType]::ParameterValue, 'Log in')
                    [CompletionResult]::new('logout', 'logout', [CompletionResultType]::ParameterValue, 'Log out')
                }
            }
            break
        }
        'myapp;auth;login' {
            [CompletionResult]::new('--browser', '--browser', [CompletionResultType]::ParameterName, 'Open browser')
            break
        }
    })

    $completions | Where-Object { $_.CompletionText -like "$wordToComplete*" } |
        Sort-Object -Property ListItemText
}
