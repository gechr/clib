# myapp Elvish completion

use str
use re

set edit:completion:arg-completer['myapp'] = {|@words|
    var n = (count $words)
    var cur = $words[-1]
    var prior = $words[1..(- $n 1)]
    var command = 'myapp'
    for w $prior {
        if (str:has-prefix $w '-') { continue }
        var next = ''
        if (and (eq $command 'myapp') (eq $w 'run')) { set next = 'myapp;run' }
        if (and (eq $command 'myapp') (eq $w 'version')) { set next = 'myapp;version' }
        if (eq $next '') { break }
        set command = $next
    }
    var prev = ''
    if (> (count $prior) 0) { set prev = $prior[-1] }

    if (eq $command 'myapp') {
        if (eq $prev '--color') {
            put 'auto'
            put 'always'
            put 'never'
        } elif (eq $prev '--config') {
            nop
        } else {
            edit:complex-candidate '--color' &display='--color  Color mode'
            edit:complex-candidate '--config' &display='--config  Config file'
            edit:complex-candidate '-h' &display='-h  Show help'
            edit:complex-candidate '--help' &display='--help  Show help'
            edit:complex-candidate '--no-config' &display='--no-config  Disable config'
            edit:complex-candidate '--no-proxy' &display='--no-proxy  Ignore proxies'
            edit:complex-candidate '--verbose' &display='--verbose  Verbose output'
            edit:complex-candidate '-v' &display='-v  Verbose output'
            edit:complex-candidate 'run' &display='run  Run command'
            edit:complex-candidate 'version' &display='version  Show version'
        }
    } elif (eq $command 'myapp;run') {
        if (or (eq $prev '--output') (eq $prev '-o')) {
            put 'text'
            put 'json'
        } else {
            edit:complex-candidate '--dry-run' &display='--dry-run  Dry run'
            edit:complex-candidate '-n' &display='-n  Dry run'
            edit:complex-candidate '--output' &display='--output  Output format'
            edit:complex-candidate '-o' &display='-o  Output format'
        }
    }
}
