# myapp Elvish completion

use str
use re

set edit:completion:arg-completer['myapp'] = {|@words|
    var n = (count $words)
    var cur = $words[-1]
    var prior = $words[1..(- $n 1)]
    var command = 'myapp'
    for w $prior {
        if (str:has-prefix $w '-') { continue }
        var next = ''
        if (and (eq $command 'myapp') (eq $w 'auth')) { set next = 'myapp;auth' }
        if (and (eq $command 'myapp;auth') (eq $w 'login')) { set next = 'myapp;auth;login' }
        if (and (eq $command 'myapp;auth') (eq $w 'logout')) { set next = 'myapp;auth;logout' }
        if (and (eq $command 'myapp') (eq $w 'run')) { set next = 'myapp;run' }
        if (eq $next '') { break }
        set command = $next
    }
    var prev = ''
    if (> (count $prior) 0) { set prev = $prior[-1] }

    if (eq $command 'myapp') {
        edit:complex-candidate '--verbose' &display='--verbose  Verbose'
        edit:complex-candidate 'auth' &display='auth  Manage authentication'
        edit:complex-candidate 'run' &display='run  Run command'
    } elif (eq $command 'myapp;auth') {
        if (eq $prev '--token') {
            nop
        } else {
            edit:complex-candidate '--token' &display='--token  Auth token'
            edit:complex-candidate 'login' &display='login  Log in'
            edit:complex-candidate 'logout' &display='logout  Log out'
        }
    } elif (eq $command 'myapp;auth;login') {
        edit:complex-candidate '--browser' &display='--browser  Open browser'
    }
}
