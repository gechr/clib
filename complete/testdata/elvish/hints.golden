# myapp Elvish completion

use str
use re

set edit:completion:arg-completer['myapp'] = {|@words|
    var n = (count $words)
    var cur = $words[-1]
    var prior = $words[1..(- $n 1)]
    var command = 'myapp'
    var prev = ''
    if (> (count $prior) 0) { set prev = $prior[-1] }

    if (eq $command 'myapp') {
        if (or (eq $prev '--config') (eq $prev '-c')) {
            edit:complete-filename $cur | each {|c|
                var s = $c
                if (not-eq (kind-of $c) string) { set s = $c[stem] }
                if (or (str:has-suffix $s '/') (str:has-suffix $s '.yaml') (str:has-suffix $s '.yml')) { put $c }
            }
        } elif (or (eq $prev '--dir') (eq $prev '-d')) {
            edit:complete-dirname $cur
        } elif (eq $prev '--host') {
            nop
        } elif (or (eq $prev '--output') (eq $prev '-o')) {
            edit:complete-filename $cur
        } elif (eq $prev '--shell') {
            edit:complete-filename $cur
        } elif (eq $prev '--user') {
            nop
        } else {
            edit:complex-candidate '--config' &display='--config  Config file'
            edit:complex-candidate '-c' &display='-c  Config file'
            edit:complex-candidate '--dir' &display='--dir  Directory'
            edit:complex-candidate '-d' &display='-d  Directory'
            edit:complex-candidate '--host' &display='--host  Host name'
            edit:complex-candidate '--output' &display='--output  Output path'
            edit:complex-candidate '-o' &display='-o  Output path'
            edit:complex-candidate '--shell' &display='--shell  Shell command'
            edit:complex-candidate '--user' &display='--user  User name'
            edit:complex-candidate '--verbose' &display='--verbose  Verbose output'
            edit:complex-candidate '-v' &display='-v  Verbose output'
        }
    }
}
