# myapp Elvish completion

use str
use re

set edit:completion:arg-completer['myapp'] = {|@words|
    var n = (count $words)
    var cur = $words[-1]
    var prior = $words[1..(- $n 1)]
    var command = 'myapp'
    var prev = ''
    if (> (count $prior) 0) { set prev = $prior[-1] }

    if (eq $command 'myapp') {
        if (eq $prev '-i') {
            nop
        } elif (eq $prev '--include') {
            nop
        } else {
            edit:complex-candidate '-i' &display='-i  Filter by regex'
            edit:complex-candidate '--include' &display='--include  Include by name'
            edit:complex-candidate '--verbose' &display='--verbose  Verbose output'
        }
    }
}
