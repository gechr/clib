# myapp Elvish completion

use str
use re

set edit:completion:arg-completer['myapp'] = {|@words|
    var n = (count $words)
    var cur = $words[-1]
    var prior = $words[1..(- $n 1)]
    var command = 'myapp'
    for w $prior {
        if (str:has-prefix $w '-') { continue }
        var next = ''
        if (and (eq $command 'myapp') (eq $w 'edit')) { set next = 'myapp;edit' }
        if (and (eq $command 'myapp') (eq $w 'list')) { set next = 'myapp;list' }
        if (eq $next '') { break }
        set command = $next
    }
    var prev = ''
    if (> (count $prior) 0) { set prev = $prior[-1] }

    if (eq $command 'myapp') {
        edit:complex-candidate '--verbose' &display='--verbose  Verbose output'
        edit:complex-candidate '-v' &display='-v  Verbose output'
        edit:complex-candidate 'edit' &display='edit  Edit files'
        edit:complex-candidate 'list' &display='list  List items'
    } elif (eq $command 'myapp;edit') {
        if (eq $prev '--editor') {
            nop
        } else {
            edit:complex-candidate '--editor' &display='--editor  Editor command'
            edit:complete-filename $cur
        }
    }
}
