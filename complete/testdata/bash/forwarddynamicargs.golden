# myapp bash completion
_myapp() {
    local i cur prev opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    prev="$3"
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"; do
        case "${cmd},${i}" in
            ",$1")
                cmd="myapp"
                ;;
            *)
                ;;
        esac
    done

    case "${cmd}" in
        myapp)
            opts="--category -c --filter --verbose -v"
            if [[ ${cur} == -* ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            case "${prev}" in
                --category|-c)
                    COMPREPLY=($(compgen -W 'alpha beta gamma' -- "${cur}"))
                    return 0
                    ;;
                --filter)
                    COMPREPLY=()
                    return 0
                    ;;
                *)
                    COMPREPLY=()
                    ;;
            esac
            local -a __dyn_pos=()
            local __skip_next=0
            local __after_dd=0
            local __fwd_name=""
            for ((j=1; j<COMP_CWORD; j++)); do
                if [[ "${__after_dd}" -eq 1 ]]; then
                    __dyn_pos+=("${COMP_WORDS[j]}")
                    continue
                fi
                if [[ "${__skip_next}" -eq 1 ]]; then
                    if [[ -n "${__fwd_name}" ]]; then
                        __dyn_pos+=("--${__fwd_name}=${COMP_WORDS[j]}")
                        __fwd_name=""
                    fi
                    __skip_next=0
                    continue
                fi
                if [[ "${COMP_WORDS[j]}" == "--" ]]; then
                    __after_dd=1
                    continue
                fi
                case "${COMP_WORDS[j]}" in
                    --category|-c)
                        __skip_next=1
                        __fwd_name="category"
                        ;;
                    --category=*)
                        __dyn_pos+=("${COMP_WORDS[j]}")
                        ;;
                    -c=*)
                        __dyn_pos+=("--category=${COMP_WORDS[j]#-c=}")
                        ;;
                    --filter)
                        __skip_next=1
                        __fwd_name="filter"
                        ;;
                    --filter=*)
                        __dyn_pos+=("${COMP_WORDS[j]}")
                        ;;
                    -*)
                        ;;
                    *)
                        __dyn_pos+=("${COMP_WORDS[j]}")
                        ;;
                esac
            done
            case ${#__dyn_pos[@]} in
                0)
                    COMPREPLY=($(compgen -W "${opts} $(myapp --@complete=items 2>/dev/null)" -- "${cur}"))
                    ;;
                1)
                    COMPREPLY=($(compgen -W "$(myapp --@complete=values -- "${__dyn_pos[@]}" 2>/dev/null)" -- "${cur}"))
                    ;;
                *)
                    COMPREPLY=($(compgen -W "$(myapp --@complete=values -- "${__dyn_pos[@]}" 2>/dev/null)" -- "${cur}"))
                    ;;
            esac
            return 0
            ;;
    esac
}

if [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 4 || "${BASH_VERSINFO[0]}" -gt 4 ]]; then
    complete -F _myapp -o nosort -o bashdefault -o default myapp
else
    complete -F _myapp -o bashdefault -o default myapp
fi
