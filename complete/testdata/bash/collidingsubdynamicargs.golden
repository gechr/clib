# pdc bash completion
_pdc() {
    local i cur opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"; do
        case "${cmd},${i}" in
            ",$1")
                cmd="pdc"
                ;;
            pdc,incident)
                cmd="pdc__incident"
                ;;
            pdc__incident,show)
                cmd="pdc__incident__show"
                ;;
            pdc,user)
                cmd="pdc__user"
                ;;
            pdc__user,show)
                cmd="pdc__user__show"
                ;;
            *)
                ;;
        esac
    done

    case "${cmd}" in
        pdc)
            opts="incident user"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 1 ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
            return 0
            ;;
        pdc__incident)
            opts="show"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 2 ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
            return 0
            ;;
        pdc__incident__show)
            opts=""
            if [[ ${cur} == -* ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            local -a __dyn_pos=()
            local __skip_next=0
            local __after_dd=0
            local __cmd_skip=2
            for ((j=1; j<COMP_CWORD; j++)); do
                if [[ "${__after_dd}" -eq 1 ]]; then
                    __dyn_pos+=("${COMP_WORDS[j]}")
                    continue
                fi
                if [[ "${__skip_next}" -eq 1 ]]; then
                    __skip_next=0
                    continue
                fi
                if [[ "${COMP_WORDS[j]}" == "--" ]]; then
                    __after_dd=1
                    continue
                fi
                case "${COMP_WORDS[j]}" in
                    -*)
                        ;;
                    *)
                        if [[ $__cmd_skip -gt 0 ]]; then
                            ((__cmd_skip--))
                        else
                            __dyn_pos+=("${COMP_WORDS[j]}")
                        fi
                        ;;
                esac
            done
            case ${#__dyn_pos[@]} in
                0)
                    COMPREPLY=($(compgen -W "${opts} $(pdc --@complete=incident 2>/dev/null)" -- "${cur}"))
                    ;;
                *)
                    COMPREPLY=($(compgen -W "$(pdc --@complete=incident -- "${__dyn_pos[@]}" 2>/dev/null)" -- "${cur}"))
                    ;;
            esac
            return 0
            ;;
        pdc__user)
            opts="show"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 2 ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
            return 0
            ;;
        pdc__user__show)
            opts=""
            if [[ ${cur} == -* ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            local -a __dyn_pos=()
            local __skip_next=0
            local __after_dd=0
            local __cmd_skip=2
            for ((j=1; j<COMP_CWORD; j++)); do
                if [[ "${__after_dd}" -eq 1 ]]; then
                    __dyn_pos+=("${COMP_WORDS[j]}")
                    continue
                fi
                if [[ "${__skip_next}" -eq 1 ]]; then
                    __skip_next=0
                    continue
                fi
                if [[ "${COMP_WORDS[j]}" == "--" ]]; then
                    __after_dd=1
                    continue
                fi
                case "${COMP_WORDS[j]}" in
                    -*)
                        ;;
                    *)
                        if [[ $__cmd_skip -gt 0 ]]; then
                            ((__cmd_skip--))
                        else
                            __dyn_pos+=("${COMP_WORDS[j]}")
                        fi
                        ;;
                esac
            done
            case ${#__dyn_pos[@]} in
                0)
                    COMPREPLY=($(compgen -W "${opts} $(pdc --@complete=user 2>/dev/null)" -- "${cur}"))
                    ;;
                *)
                    COMPREPLY=($(compgen -W "$(pdc --@complete=user -- "${__dyn_pos[@]}" 2>/dev/null)" -- "${cur}"))
                    ;;
            esac
            return 0
            ;;
    esac
}

if [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 4 || "${BASH_VERSINFO[0]}" -gt 4 ]]; then
    complete -F _pdc -o nosort -o bashdefault -o default pdc
else
    complete -F _pdc -o bashdefault -o default pdc
fi
