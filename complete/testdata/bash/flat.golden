# clibapp bash completion
_clibapp() {
    local i cur prev opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    prev="$3"
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"; do
        case "${cmd},${i}" in
            ",$1")
                cmd="clibapp"
                ;;
            *)
                ;;
        esac
    done

    case "${cmd}" in
        clibapp)
            opts="--author -a --ci --columns --limit -L --merge --no-merge --state -s --verbose -v"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 1 ]]; then
                COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
                return 0
            fi
            case "${prev}" in
                --author|-a)
                    COMPREPLY=()
                    _clibapp_dynamic_values "${cur}" clibapp --@complete=author
                    return 0
                    ;;
                --ci)
                    COMPREPLY=($(compgen -W 'success failure pending' -- "${cur}"))
                    return 0
                    ;;
                --columns)
                    local prefix=""
                    local cur_val="${cur}"
                    local line
                    local -a all_vals=()
                    while IFS= read -r line || [[ -n "${line}" ]]; do
                        all_vals+=("${line}")
                    done < <(clibapp --@complete=columns 2>/dev/null)
                    local IFS=$'\n'
                    local -a avail=()
                    if [[ "${cur}" == *,* ]]; then
                        prefix="${cur%,*},"
                        cur_val="${cur##*,}"
                        IFS=',' read -ra selected <<< "${prefix}"
                        for val in "${all_vals[@]}"; do
                            local found=0
                            for sel in "${selected[@]}"; do
                                if [[ "${val}" == "${sel}" ]]; then
                                    found=1
                                    break
                                fi
                            done
                            if [[ "${found}" -eq 0 ]]; then
                                avail+=("${val}")
                            fi
                        done
                    else
                        avail=("${all_vals[@]}")
                    fi
                    COMPREPLY=($(compgen -W "${avail[*]}" -- "${cur_val}"))
                    if [[ -n "${prefix}" ]]; then
                        COMPREPLY=("${COMPREPLY[@]/#/${prefix}}")
                    fi
                    compopt -o nospace
                    return 0
                    ;;
                --limit|-L)
                    COMPREPLY=()
                    return 0
                    ;;
                --state|-s)
                    COMPREPLY=($(compgen -W 'open closed merged all' -- "${cur}"))
                    return 0
                    ;;
                *)
                    COMPREPLY=()
                    ;;
            esac
            COMPREPLY=($(compgen -W "${opts}" -- "${cur}"))
            return 0
            ;;
    esac
}

_clibapp_dynamic_values() {
    local cur="$1"
    shift
    local line
    local -a vals=()
    while IFS= read -r line || [[ -n "${line}" ]]; do
        vals+=("${line}")
    done < <("$@" 2>/dev/null)
    local IFS=$'\n'
    COMPREPLY+=($(compgen -W "${vals[*]}" -- "${cur}"))
}

if [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 4 || "${BASH_VERSINFO[0]}" -gt 4 ]]; then
    complete -F _clibapp -o nosort -o bashdefault -o default clibapp
else
    complete -F _clibapp -o bashdefault -o default clibapp
fi
